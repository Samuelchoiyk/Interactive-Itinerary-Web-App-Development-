          <FileText className="w-6 h-6" />
        </button>
        <button className="flex flex-col items-center gap-1 text-gray-400 hover:text-gray-900 transition-colors">
          <Settings className="w-6 h-6" />
        </button>
      </div>

      {/* Import / Add Modal Simulation */}
      <AnimatePresence>
        {showImportModal && (
          <>
            <motion.div 
              initial={{ opacity: 0 }}
              animate={{ opacity: 1 }}
              exit={{ opacity: 0 }}
              onClick={() => setShowImportModal(false)}
              className="fixed inset-0 bg-gray-900/40 backdrop-blur-sm z-50"
            />
            <motion.div
              initial={{ y: '100%' }}
              animate={{ y: 0 }}
              exit={{ y: '100%' }}
              transition={{ type: 'spring', damping: 25, stiffness: 200 }}
              className="fixed bottom-0 left-0 right-0 bg-white rounded-t-[40px] p-8 z-50 shadow-2xl max-w-lg mx-auto"
            >
              <div className="w-12 h-1.5 bg-gray-200 rounded-full mx-auto mb-8" />
              <h3 className="text-2xl font-bold mb-2">Import Schedule</h3>
              <p className="text-gray-500 text-sm mb-6">
                Paste text from an email, booking confirmation, or spreadsheet to magically add it to your day.
              </p>
              
              <textarea
                value={importText}
                onChange={(e) => setImportText(e.target.value)}
                placeholder="e.g. Dinner at Sushi Dai, 8:00 PM..."
                className="w-full bg-gray-50 border border-gray-200 rounded-2xl p-4 min-h-[150px] mb-6 focus:outline-none focus:ring-2 focus:ring-[#e85d04] focus:border-transparent transition-all text-sm resize-none"
              />
              
              <button 
                onClick={simulateImport}
                disabled={!importText.trim()}
                className="w-full bg-[#e85d04] disabled:bg-gray-300 text-white font-bold py-4 rounded-full shadow-lg shadow-[#e85d04]/20 transition-all flex justify-center items-center gap-2"
              >
                <Plus className="w-5 h-5" /> Add to Itinerary
              </button>
            </motion.div>
          </>
        )}
      </AnimatePresence>
    </div>
  );
}
