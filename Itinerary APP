        layout
        onClick={() => setIsExpanded(!isExpanded)}
        className="relative z-10 bg-white rounded-3xl p-5 shadow-[0_4px_20px_rgb(0,0,0,0.03)] border border-gray-50/50 cursor-pointer overflow-hidden"
