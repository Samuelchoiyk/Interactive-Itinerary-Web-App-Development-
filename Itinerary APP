export default function App() {
  const [itinerary, setItinerary] = useState(initialData);
  const [activeDayIdx, setActiveDayIdx] = useState(0);
  const [showImportModal, setShowImportModal] = useState(false);
  const [importText, setImportText] = useState('');

  const activeDay = itinerary[activeDayIdx];

  const handleDeleteItem = (dayId, itemId) => {
    setItinerary(prev => prev.map(day => {
      if (day.id === dayId) {
        return { ...day, items: day.items.filter(i => i.id !== itemId) };
      }
      return day;
    }));
  };

  const handleUpdateNotes = (dayId, itemId, newNotes) => {
    setItinerary(prev => prev.map(day => {
      if (day.id === dayId) {
        return {
          ...day,
          items: day.items.map(i => i.id === itemId ? { ...i, notes: newNotes } : i)
        };
      }
      return day;
    }));
  };

  const simulateImport = () => {
    // A highly simplified mock importer that parses a block of text
    // In a real app, this would use SheetJS for Excel, or an LLM for free-text.
    const newItem = {
      id: `item-${Date.now()}`,
      time: '08:00 PM',
      title: 'Dinner Reservation (Imported)',
      type: 'restaurant',
      location: 'Unknown Location',
      details: importText.substring(0, 50) + '...',
      notes: 'Imported via text parser.',
    };

    setItinerary(prev => {
      const newItin = [...prev];
      newItin[activeDayIdx].items.push(newItem);
      return newItin;
    });
    
    setImportText('');
    setShowImportModal(false);
  };

  // Handle Swipe left/right between days
  const handlePageDragEnd = (event, info) => {
    const swipeThreshold = 50;
    if (info.offset.x < -swipeThreshold && activeDayIdx < itinerary.length - 1) {
      setActiveDayIdx(activeDayIdx + 1); // Swipe left -> Next day
    } else if (info.offset.x > swipeThreshold && activeDayIdx > 0) {
      setActiveDayIdx(activeDayIdx - 1); // Swipe right -> Prev day
    }
  };

  return (
    <div className="min-h-screen bg-[#F8F9FA] text-gray-900 font-sans selection:bg-[#e85d04]/20 pb-24 overflow-x-hidden">
      
      {/* Top Header Section */}
