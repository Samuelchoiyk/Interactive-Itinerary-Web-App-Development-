  const [localNotes, setLocalNotes] = useState(item.notes || '');

  const handleDragEnd = (event, info) => {
    // If swiped far enough to the left, delete
    if (info.offset.x < -100) {
      onDelete(item.id);
    }
  };

  const handleSaveNotes = (e) => {
    e.stopPropagation();
    onUpdateNotes(item.id, localNotes);
  };

  return (
    <motion.div
      layout
      drag="x"
      dragConstraints={{ left: 0, right: 0 }}
      dragElastic={{ left: 0.5, right: 0 }}
      onDragEnd={handleDragEnd}
      className="relative w-full mb-4 touch-pan-y"
    >
      {/* Background Delete Indicator */}
      <div className="absolute inset-0 bg-red-100 rounded-3xl flex items-center justify-end px-6 z-0">
        <Trash2 className="text-red-500 w-6 h-6" />
      </div>

      {/* Main Card */}
