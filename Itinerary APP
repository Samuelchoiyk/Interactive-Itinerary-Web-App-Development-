            <h1 className="text-2xl font-black tracking-tight text-gray-900">
              Travo<span className="text-[#e85d04]">.</span>
            </h1>
            <p className="text-sm text-gray-500 font-medium mt-1">Trip to Tokyo, Japan</p>
          </div>
          <div className="w-12 h-12 bg-gray-100 rounded-full border-2 border-white shadow-sm overflow-hidden flex justify-center items-center">
             <User className="text-gray-400 w-6 h-6" />
          </div>
        </div>

        {/* Info Cards (Weather & Time) */}
        <div className="flex gap-3 overflow-x-auto pb-2 scrollbar-hide">
          <div className="flex-shrink-0 bg-blue-50 text-blue-900 px-4 py-3 rounded-2xl flex items-center gap-3 w-40">
            <CloudSun className="w-8 h-8 text-blue-400" />
            <div>
              <p className="text-xs opacity-70 font-semibold uppercase tracking-wider">Local</p>
              <p className="font-bold text-sm">{activeDay.weather}</p>
            </div>
          </div>
          <div className="flex-shrink-0 bg-orange-50 text-orange-900 px-4 py-3 rounded-2xl flex items-center gap-3 w-40">
            <Clock className="w-8 h-8 text-[#e85d04]" />
            <div>
              <p className="text-xs opacity-70 font-semibold uppercase tracking-wider">Time</p>
              <p className="font-bold text-sm">{activeDay.localTime}</p>
            </div>
          </div>
        </div>
      </header>

      {/* Main Content Area */}
      <main className="px-6 pt-8 max-w-lg mx-auto">
        
        {/* Day Navigation Tabs */}
        <div className="flex items-center justify-between mb-6">
          <div className="flex gap-2 bg-gray-200/50 p-1.5 rounded-full">
            {itinerary.map((day, idx) => (
              <button
                key={day.id}
                onClick={() => setActiveDayIdx(idx)}
                className={`px-5 py-2 rounded-full text-sm font-bold transition-all ${
                  activeDayIdx === idx 
                    ? 'bg-white text-gray-900 shadow-sm' 
                    : 'text-gray-500 hover:text-gray-700'
                }`}
              >
                Day {idx + 1}
              </button>
            ))}
          </div>
          
          <button 
            onClick={() => setShowImportModal(true)}
